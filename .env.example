# WeKruit Matching Engine — environment variables
# Copy this file to .env and fill in your values.
# All variables are required unless marked [optional].

# PostgreSQL connection string (psycopg3 format — use postgresql+psycopg://, NOT postgresql+psycopg2://)
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/wekruit

# Anthropic API key — used for LLM enrichment (Phase 3)
# Get from: console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — used for text-embedding-3-small (Phase 4)
# Get from: platform.openai.com -> API keys
OPENAI_API_KEY=sk-...

# GitHub Personal Access Token — used for authenticated raw.githubusercontent.com fetches (Phase 2)
# Required scopes: public_repo (read-only is sufficient)
# Get from: github.com -> Settings -> Developer settings -> Personal access tokens (classic)
GITHUB_TOKEN=github_pat_...

# [optional] Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

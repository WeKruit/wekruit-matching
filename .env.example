# WeKruit Matching Engine — environment configuration
# Copy this file: cp .env.example .env
# Then fill in your actual values. All variables required unless marked [optional].

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (psycopg3 format)
# IMPORTANT: Use postgresql+psycopg:// NOT postgresql+psycopg2://
# Where to get: Your local Postgres install or hosted provider (Supabase, Neon, Railway)
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/wekruit

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Used for LLM enrichment (classify industry, skills, sponsorship via Claude Haiku)
# Where to get: console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used for semantic embedding generation (text-embedding-3-small, 1536 dims)
# Where to get: platform.openai.com -> API keys
OPENAI_API_KEY=sk-...

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token for authenticated raw.githubusercontent.com fetches
# Required scopes: public_repo (read-only is sufficient)
# Where to get: github.com -> Settings -> Developer settings -> Personal access tokens (classic)
GITHUB_TOKEN=github_pat_...

# ── API Authentication ───────────────────────────────────────────────────────
# Secret key for X-API-Key header on all protected endpoints
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=change-me-to-a-real-secret

# ── Logging ───────────────────────────────────────────────────────────────────
# [optional] Log verbosity. Valid: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

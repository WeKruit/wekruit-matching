# wekruit-matching — Docker-compose env template.
#
# Copy: cp .env.docker.example .env  (and chmod 600 .env)
# Then fill the secrets below. Lines starting with `#` are comments.
#
# DATABASE_URL is intentionally OMITTED — docker-compose injects it pointing
# at the sibling `db` service. If you run the app outside compose, add your
# own DATABASE_URL here.

# ── Postgres ─────────────────────────────────────────────────────────────────
# Used by the `db` service in compose. Pick anything for local; rotate before
# exposing the port publicly.
POSTGRES_PASSWORD=wekruit_local_dev

# ── LLM / scrape providers ──────────────────────────────────────────────────
# All four required for full pipeline. Leaving any of them blank breaks
# pipeline.daily; see src/wekruit_matching/config.py for which stages depend
# on which provider.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
SILICONFLOW_API_KEY=sk-...
GITHUB_TOKEN=github_pat_...

# ── Server auth ──────────────────────────────────────────────────────────────
# Required for the FastAPI server. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=change-me-to-a-real-secret

# ── Firecrawl ────────────────────────────────────────────────────────────────
# Optional. Leave blank to skip Firecrawl-dependent JD enrichment.
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# ── Serper.dev ───────────────────────────────────────────────────────────────
# Optional. Used for URL-resolution fallback (2500 free queries/month).
SERPER_API_KEY=

# ── Mailgun ──────────────────────────────────────────────────────────────────
# Optional. Pipeline runs without it, just skips end-of-run email.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=wekruit.com
PIPELINE_NOTIFY_EMAIL=admin1@wekruit.com

# ── Firebase sync ────────────────────────────────────────────────────────────
# Required for the Stage 4 sync to push enriched jobs into matching-jobs.
FIREBASE_SYNC_URL=https://us-central1-wekruit-5f89b.cloudfunctions.net/syncMatchingJobs
FIREBASE_SYNC_API_KEY=
FIREBASE_SYNC_BATCH_SIZE=50
FIREBASE_SYNC_TIMEOUT_SECONDS=30
FIREBASE_SYNC_COLLECTION=matching-jobs

# ── PA derivedExperience read path ──────────────────────────────────────────
# Optional. When `true`, /match reads pa-users/{uid}.derivedExperience from
# Firestore for ranker signals.
MATCHING_USE_DERIVED_EXPERIENCE=false
FIRESTORE_PROJECT_ID=wekruit-5f89b
# Paste the FULL service-account JSON on a single line (escape inner quotes).
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
